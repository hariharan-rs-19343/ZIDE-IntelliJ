<idea-plugin>
    <id>com.zoho.dzide</id>
    <name>ZIDE</name>
    <vendor>Zoho</vendor>
    <description><![CDATA[
        <p>ZIDE brings Zoho's server development workflow to IntelliJ IDEA — manage Tomcat servers, deploy, debug, and iterate on code without leaving the IDE.</p>
        <h3>Server Management</h3>
        <ul>
            <li>Add, edit, and remove Tomcat server configurations from a dedicated tool window</li>
            <li>Start, stop, and restart servers with real-time log streaming</li>
            <li>Run and debug Java projects on Tomcat with JPDA auto-attach</li>
        </ul>
        <h3>Deploy Sync</h3>
        <ul>
            <li>Auto-compile and hot-swap Java classes on save (debug mode)</li>
            <li>ANT hook tasks and auto-resource copy for JSP, JS, CSS, and XML changes</li>
            <li>Compiled class files synced to deployment WEB-INF/classes/</li>
        </ul>
        <h3>ZIDE Integration</h3>
        <ul>
            <li>Auto-configure from Eclipse ZIDE projects (.zide_resources/)</li>
            <li>Deployment config patching — server.xml, web.xml, persistence, and security configs</li>
            <li>Update Deployment — deploy zip archives to the ZIDE deployment folder</li>
        </ul>
        <h3>Productivity</h3>
        <ul>
            <li>ZIDE menu with keyboard shortcuts for Run, Debug, Stop, and Build</li>
            <li>App Logs viewer with color-coded ERROR/WARN highlighting</li>
        </ul>
    ]]></description>

    <change-notes><![CDATA[
        <b>0.0.5</b>
        <ul>
            <li>Deployment Properties editor — view and edit ZIDE properties (Host Name, IAM Server, ports, etc.) from the ZIDE menu; read-only mode when server is running</li>
            <li>Kill Tomcat servers on IDE quit/restart — servers are now properly stopped when IntelliJ closes</li>
            <li>Breakpoints fix — debug sessions now set the module classpath so breakpoints resolve to source files</li>
            <li>JPDA address uses *:port format for JDK 9+ compatibility</li>
            <li>Thread-safe server process tracking with ConcurrentHashMap</li>
            <li>Server picker fix — multi-server selection now uses a modal dialog instead of async popup</li>
            <li>App Logs tail-read — only loads last 5000 lines to prevent OOM on large log files</li>
            <li>Build output fix — ANT console output no longer shows extra empty lines</li>
            <li>Code cleanup — removed stale files, dead code, and extracted shared utilities</li>
        </ul>
        <b>0.0.4</b>
        <ul>
            <li>Hot-swap on save — Java class changes are hot-swapped into the running JVM via JDWP when a debug session is active</li>
            <li>Deploy-sync copies compiled .class files to deployment WEB-INF/classes/ after every successful build</li>
            <li>Broader compiler output detection — searches out/production/, bin/production/, target/classes/, build/classes/, and bin/ for compiled classes</li>
        </ul>
        <b>0.0.3</b>
        <ul>
            <li>Keyboard shortcuts — Run (Ctrl+Shift+I), Debug (Ctrl+Shift+D), Stop (Ctrl+Shift+.), Build (Ctrl+Shift+B)</li>
            <li>Plugin zip renamed to zide-intelliJ-plugin-{version}.zip</li>
        </ul>
        <b>0.0.2</b>
        <ul>
            <li>Deployment config patching — automatically patches server.xml, web.xml, persistence-configurations.xml, and security-properties.xml before server start</li>
            <li>Pre-start setup — runs postzidedeploy.sh and syncs server.xml files between Servers config and Tomcat directories</li>
            <li>Toolbar buttons — Stop and Restart on the Servers tab, Refresh on the App Logs tab</li>
            <li>Restart server action — stops, waits for port release, then starts again</li>
            <li>Auto-stop before start — if server is already running, stops it first before starting/debugging</li>
            <li>Debug fix — no longer probes debug port with raw TCP (was corrupting JDWP handshake)</li>
            <li>Debug fix — shell export commands now properly separated with &amp;&amp;</li>
            <li>VM arguments loaded from Zide.properties instead of hardcoded defaults</li>
            <li>CATALINA_OPTS only set when launch args are configured</li>
            <li>Regex.escapeReplacement fix for security-properties.xml patching</li>
            <li>Suppressed noisy Tomcat stderr messages in Output console</li>
        </ul>
        <b>0.0.1 — Initial Release</b>
        <ul>
            <li>SAS-ZIDE tool window with Servers, Output, and App Logs tabs</li>
            <li>Add / Edit / Remove Tomcat server configurations</li>
            <li>Run server in foreground mode (catalina.sh run)</li>
            <li>Debug with JPDA auto-attach (waits for debug port readiness)</li>
            <li>Stop server by destroying the attached process</li>
            <li>ANT build integration from project directory</li>
            <li>Update Deployment — deploy zip to ZIDE deployment folder</li>
            <li>App Logs viewer with color-coded ERROR/WARN highlighting</li>
            <li>Deploy-sync on save: class file copy, ANT hooks, auto-resource copy</li>
            <li>ZIDE auto-configuration from Eclipse .zide_resources/</li>
            <li>ZIDE menu in the main menu bar</li>
            <li>Debug on Tomcat in Project View context menu</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Startup activity -->
        <postStartupActivity implementation="com.zoho.dzide.DzidePlugin"/>

        <!-- Persistence -->
        <projectService serviceImplementation="com.zoho.dzide.persistence.TomcatServerState"/>
        <projectService serviceImplementation="com.zoho.dzide.persistence.ZideCacheState"/>

        <!-- Project services -->
        <projectService serviceImplementation="com.zoho.dzide.tomcat.TomcatServerProvider"/>
        <projectService serviceImplementation="com.zoho.dzide.tomcat.TomcatManager"/>
        <projectService serviceImplementation="com.zoho.dzide.deploysync.ResourceSyncManager"/>

        <!-- Tool window -->
        <toolWindow id="SAS-ZIDE"
                    anchor="bottom"
                    icon="/icons/zide-toolwindow.svg"
                    factoryClass="com.zoho.dzide.toolwindow.TomcatToolWindowFactory"/>

        <!-- Run configuration -->
        <configurationType implementation="com.zoho.dzide.runconfig.TomcatConfigurationType"/>

        <!-- Notification group -->
        <notificationGroup id="DZIDE Notifications"
                          displayType="BALLOON"
                          toolWindowId="SAS-ZIDE"/>

        <!-- File save listener for deploy sync -->
        <fileDocumentManagerListener
                implementation="com.zoho.dzide.deploysync.DeploySyncSaveListener"/>

        <!-- ZIDE New Project Wizard (modern sidebar entry) -->
        <newProjectWizard.generator implementation="com.zoho.dzide.newproject.ZideNewProjectWizard"/>

        <!-- Application-level settings persistence -->
        <applicationService serviceImplementation="com.zoho.dzide.settings.ZideSettingsState"/>

        <!-- Settings UI: Zide section under Tools -->
        <applicationConfigurable
                parentId="tools"
                id="com.zoho.dzide.settings"
                displayName="Zide"
                instance="com.zoho.dzide.settings.ZideSettingsConfigurable"/>

        <applicationConfigurable
                parentId="com.zoho.dzide.settings"
                id="com.zoho.dzide.settings.cmtool"
                displayName="CMTool"
                instance="com.zoho.dzide.settings.CmToolConfigurable"/>

        <applicationConfigurable
                parentId="com.zoho.dzide.settings"
                id="com.zoho.dzide.settings.wget"
                displayName="Wget Configuration"
                instance="com.zoho.dzide.settings.WgetConfigurable"/>

        <applicationConfigurable
                parentId="com.zoho.dzide.settings"
                id="com.zoho.dzide.settings.git"
                displayName="Git"
                instance="com.zoho.dzide.settings.GitConfigurable"/>

        <applicationConfigurable
                parentId="com.zoho.dzide.settings"
                id="com.zoho.dzide.settings.zohorepo"
                displayName="Zoho Repository"
                instance="com.zoho.dzide.settings.ZohoRepoConfigurable"/>
    </extensions>

    <actions>
        <!-- ZIDE top-level menu in the main menu bar -->
        <group id="dzide.MainMenu"
               text="ZIDE"
               description="ZIDE Tomcat Server Management"
               popup="true">
            <add-to-group group-id="MainMenu" anchor="before" relative-to-action="HelpMenu"/>

            <action id="dzide.NewProject"
                    class="com.zoho.dzide.newproject.ZideNewProjectAction"
                    text="New Project"
                    description="Create a new ZIDE project"
                    icon="AllIcons.Actions.NewFolder"/>

            <action id="dzide.UninstallProject"
                    class="com.zoho.dzide.actions.UninstallProjectAction"
                    text="Uninstall Project"
                    description="Remove ZIDE project, deployment folder, and server configuration"
                    icon="AllIcons.Actions.GC"/>

            <separator/>

            <action id="dzide.AddServer"
                    class="com.zoho.dzide.actions.AddServerAction"
                    text="Add Tomcat Server"
                    description="Add a new Tomcat server"
                    icon="AllIcons.General.Add"/>

            <action id="dzide.EditServer"
                    class="com.zoho.dzide.actions.EditServerAction"
                    text="Edit Server"
                    description="Edit Tomcat server settings"
                    icon="AllIcons.Actions.Edit"/>

            <separator/>

            <action id="dzide.StartServer"
                    class="com.zoho.dzide.actions.StartServerAction"
                    text="Run"
                    description="Start Tomcat server"
                    icon="AllIcons.Actions.Execute">
                <keyboard-shortcut keymap="$default" first-keystroke="control shift I"/>
            </action>

            <action id="dzide.DebugOnServer"
                    class="com.zoho.dzide.actions.DebugOnServerAction"
                    text="Debug"
                    description="Debug project on Tomcat"
                    icon="AllIcons.Actions.StartDebugger">
                <keyboard-shortcut keymap="$default" first-keystroke="control shift D"/>
            </action>

            <action id="dzide.StopServer"
                    class="com.zoho.dzide.actions.StopServerAction"
                    text="Stop"
                    description="Stop Tomcat server"
                    icon="AllIcons.Actions.Suspend">
                <keyboard-shortcut keymap="$default" first-keystroke="control shift PERIOD"/>
            </action>

            <action id="dzide.RefreshServers"
                    class="com.zoho.dzide.actions.RefreshServersAction"
                    text="Refresh"
                    description="Refresh server status"
                    icon="AllIcons.Actions.Refresh"/>

            <separator/>

            <action id="dzide.Build"
                    class="com.zoho.dzide.actions.BuildAction"
                    text="Build"
                    description="Run ANT build script"
                    icon="AllIcons.Actions.Compile">
                <keyboard-shortcut keymap="$default" first-keystroke="control shift B"/>
            </action>

            <group id="dzide.RunHooksGroup"
                   text="Run Hooks"
                   description="Run ZIDE ANT hooks"
                   popup="true"
                   icon="AllIcons.Actions.Lightning">

                <action id="dzide.RunAllHooks"
                        class="com.zoho.dzide.actions.RunHooksAction$RunAllHooks"
                        text="Run All Hooks"
                        description="Run all ZIDE hooks (precreation + postcreation + zidemodule)"
                        icon="AllIcons.Actions.RunAll"/>

                <separator/>

                <action id="dzide.RunPrecreationHook"
                        class="com.zoho.dzide.actions.RunHooksAction$RunPrecreationHook"
                        text="Run Precreation Hook"
                        description="Run precreationhook from zide_hook/"
                        icon="AllIcons.Actions.Execute"/>

                <action id="dzide.RunPostcreationHook"
                        class="com.zoho.dzide.actions.RunHooksAction$RunPostcreationHook"
                        text="Run Postcreation Hook"
                        description="Run postcreationhook from zide_build/"
                        icon="AllIcons.Actions.Execute"/>

                <action id="dzide.RunZideModuleHook"
                        class="com.zoho.dzide.actions.RunHooksAction$RunZideModuleHook"
                        text="Run ZideModule Hook"
                        description="Run zidemodulehook from zide_hook/"
                        icon="AllIcons.Actions.Execute"/>
            </group>

            <action id="dzide.DeploymentProperties"
                    class="com.zoho.dzide.actions.DeploymentPropertiesAction"
                    text="Deployment Properties"
                    description="Edit ZIDE deployment properties"
                    icon="AllIcons.General.Settings"/>

            <group id="dzide.UpdateDeploymentGroup"
                   text="Update Deployment"
                   description="Deploy to server"
                   popup="true"
                   icon="AllIcons.Actions.Upload">

                <action id="dzide.CustomBuild"
                        class="com.zoho.dzide.actions.CustomBuildAction"
                        text="Custom Build"
                        description="Deploy from a remote build URL"
                        icon="AllIcons.Actions.Download">
                    <keyboard-shortcut keymap="$default" first-keystroke="control shift alt U"/>
                </action>

                <action id="dzide.LocalBuild"
                        class="com.zoho.dzide.actions.UpdateDeploymentAction"
                        text="Local Build"
                        description="Deploy a local zip file to the server"
                        icon="AllIcons.Actions.Upload">
                    <keyboard-shortcut keymap="$default" first-keystroke="meta shift U"/>
                </action>
            </group>

            <action id="dzide.AppLogs"
                    class="com.zoho.dzide.actions.AppLogsAction"
                    text="App Logs"
                    description="Show application logs"
                    icon="AllIcons.Debugger.Console">
                <keyboard-shortcut keymap="$default" first-keystroke="control shift L"/>
            </action>
        </group>

        <!-- Toolbar-only actions (not in ZIDE menu) -->
        <action id="dzide.RemoveServer"
                class="com.zoho.dzide.actions.RemoveServerAction"
                text="Remove Server"
                description="Remove this Tomcat server"
                icon="AllIcons.General.Remove"/>

        <action id="dzide.RestartServer"
                class="com.zoho.dzide.actions.RestartServerAction"
                text="Restart"
                description="Restart Tomcat server"
                icon="AllIcons.Actions.Restart"/>

        <action id="dzide.RefreshAppLogs"
                class="com.zoho.dzide.actions.RefreshAppLogsAction"
                text="Refresh App Logs"
                description="Reload application log file"
                icon="AllIcons.Actions.Refresh"/>

        <!-- Debug in project view right-click menu -->
        <action id="dzide.DebugOnServer.ProjectView"
                class="com.zoho.dzide.actions.DebugOnServerAction"
                text="Debug on Tomcat Server"
                description="Debug project on Tomcat"
                icon="AllIcons.Actions.StartDebugger">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
